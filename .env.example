# Julia API keys — copy to .env and fill in
# Real keys must NEVER be committed (.env is gitignored)

# Anthropic — Claude (conversation brain)
ANTHROPIC_API_KEY=

# OpenAI — Whisper STT + text-embedding-3-large (corpus embeddings)
OPENAI_API_KEY=

# ElevenLabs — TTS for Julia's voice on web
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Vapi — phone-channel orchestration (optional; for the phone demo only)
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
